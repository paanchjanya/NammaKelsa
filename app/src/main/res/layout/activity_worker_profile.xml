<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Top bar with logout -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/title_profile"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#0b070d" />

            <TextView
                android:id="@+id/btnLogout"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_logout"
                android:textSize="13sp"
                android:textColor="#FF6B35"
                android:padding="8dp"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground"/>

        </LinearLayout>

        <!-- Profile Photo -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/label_profile_photo" android:textStyle="bold"
            android:textColor="#1A1A1A" android:layout_marginBottom="8dp"/>

        <ImageView
            android:id="@+id/ivProfilePhoto"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_gravity="center_horizontal"
            android:background="#F0F0F0"
            android:scaleType="centerCrop"/>

        <Button
            android:id="@+id/btnPickProfilePhoto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/btn_pick_photo"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="24dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

        <!-- Name -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_full_name"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:boxStrokeColor="#555555"
            app:boxStrokeWidth="2dp"
            android:layout_marginBottom="16dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#000000"
                android:textColorHint="#666666"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Phone -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_phone"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:boxStrokeColor="#555555"
            app:boxStrokeWidth="2dp"
            android:layout_marginBottom="16dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etPhone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="phone"
                android:textColor="#000000"
                android:textColorHint="#666666"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Daily Rate -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_daily_rate"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:boxStrokeColor="#555555"
            app:boxStrokeWidth="2dp"
            android:layout_marginBottom="16dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etDailyRate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="numberDecimal"
                android:textColor="#000000"
                android:textColorHint="#666666"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Location -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/hint_locality"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            app:boxStrokeColor="#555555"
            app:boxStrokeWidth="2dp"
            android:layout_marginBottom="24dp">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etLocation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#000000"
                android:textColorHint="#666666"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- AI Skill Suggester -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFF8F5">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/title_ai_skill_suggester"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="#FF6B35"
                    android:layout_marginBottom="10dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_work_description_ai"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                    app:boxStrokeColor="#555555"
                    app:boxStrokeWidth="2dp"
                    android:layout_marginBottom="10dp">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etWorkDescription"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textMultiLine"
                        android:minLines="2"
                        android:textColor="#000000"
                        android:textColorHint="#666666"/>
                </com.google.android.material.textfield.TextInputLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvSuggestedSkill"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/msg_suggested_skill_placeholder"
                        android:textSize="12sp"
                        android:textColor="#888888"/>

                    <Button
                        android:id="@+id/btnSuggestSkill"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="@string/btn_suggest"
                        android:textSize="12sp"
                        android:backgroundTint="#FF6B35"
                        style="@style/Widget.MaterialComponents.Button"/>

                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Skill Selection -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/label_select_skill" android:textStyle="bold"
            android:textColor="#1A1A1A" android:layout_marginBottom="10dp"/>

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupSkills"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:singleSelection="true"
            android:layout_marginBottom="24dp"/>

        <!-- Work Gallery -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/label_work_gallery" android:textStyle="bold"
            android:textColor="#1A1A1A" android:layout_marginBottom="10dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3"
            android:layout_marginBottom="16dp">

            <ImageView android:id="@+id/ivWork1"
                android:layout_width="0dp" android:layout_height="100dp"
                android:layout_weight="1" android:background="#F0F0F0"
                android:scaleType="centerCrop" android:layout_margin="4dp"/>

            <ImageView android:id="@+id/ivWork2"
                android:layout_width="0dp" android:layout_height="100dp"
                android:layout_weight="1" android:background="#F0F0F0"
                android:scaleType="centerCrop" android:layout_margin="4dp"/>

            <ImageView android:id="@+id/ivWork3"
                android:layout_width="0dp" android:layout_height="100dp"
                android:layout_weight="1" android:background="#F0F0F0"
                android:scaleType="centerCrop" android:layout_margin="4dp"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnPickWorkPhotos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_pick_work_photos"
            android:layout_marginBottom="24dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>

        <!-- AI Bio Generator -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="#FFF8F5">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/title_ai_worker_bio"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="#FF6B35"/>

                    <Button
                        android:id="@+id/btnGenerateBio"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="@string/btn_generate"
                        android:textSize="12sp"
                        android:backgroundTint="#FF6B35"
                        style="@style/Widget.MaterialComponents.Button"/>

                </LinearLayout>

                <TextView
                    android:id="@+id/tvGeneratedBio"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/msg_ai_bio_placeholder"
                    android:textSize="13sp"
                    android:textColor="#888888"
                    android:lineSpacingMultiplier="1.5"
                    android:minLines="4"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <Button
            android:id="@+id/btnSaveProfile"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/btn_save_profile"
            android:backgroundTint="#FF6B35"
            android:layout_marginBottom="24dp"/>

        <!-- Availability Toggle -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#EEEEEE"
            android:layout_marginBottom="20dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="20dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/label_available_today"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#1A1A1A"/>

                <TextView
                    android:id="@+id/tvAvailabilityStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/status_offline"
                    android:textSize="13sp"
                    android:textColor="#888888"
                    android:layout_marginTop="2dp"/>

            </LinearLayout>

            <com.google.android.material.switchmaterial.SwitchMaterial
                android:id="@+id/switchAvailability"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:checked="false"
                app:trackTint="@color/selector_switch_track"/>

        </LinearLayout>

    </LinearLayout>
</ScrollView>